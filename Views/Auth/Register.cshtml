@{
    ViewData["Title"] = "Registrera";
}

<center>
    <h2>Suverän Bank</h2>
    <h3>Bli kund idag!</h3>
    <p><i>Få 10,000 SEK när du registrerar dig!</i></p>

    @if (ViewBag.Error != null)
    {
        <p style="color: red;"><b>@ViewBag.Error</b></p>
    }

    <form method="post" asp-controller="Auth" asp-action="Register">
        <table border="0" cellpadding="5">
            <tr>
                <td align="right"><b>Ditt namn:</b></td>
                <td><input type="text" name="fullName" size="30" /></td>
            </tr>
            <tr>
                <td align="right"><b>Användarnamn:</b></td>
                <td><input type="text" name="username" size="30" /></td>
            </tr>
            <tr>
                <td align="right"><b>Lösenord:</b></td>
                <td><input type="password" name="password" size="30" /></td>
            </tr>
            <tr>
                <td colspan="2" align="center">
                    <input type="submit" value="Skicka in" />
                </td>
            </tr>
        </table>
    </form>

    <p>
        <a asp-controller="Auth" asp-action="Login">Redan kund? Logga in här!</a>
    </p>
</center>